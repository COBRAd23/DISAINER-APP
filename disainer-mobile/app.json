{
  "expo": {
    "name": "disainer-mobile",
    "slug": "disainer-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconoapp.png",
    "scheme": "disainermobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/iconoapp.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.disainermobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashscreem.png",
          "imageWidth": 400,
          "resizeMode": "cover",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
